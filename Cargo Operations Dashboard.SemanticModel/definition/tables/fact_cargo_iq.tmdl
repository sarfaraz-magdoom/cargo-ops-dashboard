	column 'Milestone Outcome' = SWITCH ( TRUE(), fact_cargo_iq[fap] = 1 && fact_cargo_iq[dap] = 1, "Both Planned & Actual", fact_cargo_iq[fap] = 1 && fact_cargo_iq[dap] = 0, "Planned Only (FAP)", fact_cargo_iq[fap] = 0 && fact_cargo_iq[dap] = 1, "Actual Only (DAP)", "Neither" )
		dataType: string
		lineageTag: 1f999379-8fc0-494f-a609-ce56724aae8f

	column 'Slippage Direction' = VAR s = fact_cargo_iq[slippage_min] RETURN SWITCH ( TRUE(), s < 0, "Ahead of Schedule", s = 0, "On Milestone", s <= 60, "Slight Slip (<1h)", s <= 240, "Moderate Slip (1-4h)", "Severe Slip (4h+)" )
		dataType: string
		lineageTag: 53a32ef4-f8c2-48fe-8576-105af22f8051

	column 'Dwell Band Sort' = VAR d = fact_cargo_iq[dwell_min] RETURN SWITCH ( TRUE(), d < 0, 0, d <= 720, 1, d <= 1440, 2, d <= 4320, 3, 4 )
		dataType: int64
		lineageTag: 3468df2f-bce0-4d1f-a815-3000037cc931

	column 'Dwell Band' = VAR d = fact_cargo_iq[dwell_min] RETURN SWITCH ( TRUE(), d < 0, "Anomalous (negative)", d <= 720, "Fast (<12h)", d <= 1440, "Normal (12-24h)", d <= 4320, "Slow (1-3 days)", "Stuck (3+ days)" )
		dataType: string
		lineageTag: 38410ddb-f2f1-4a59-a961-571ef8996557
		sortByColumn: 'Dwell Band Sort'

